@baseUrl = http://localhost:8080
@token = paste-access-token-here
@planId = 1
@customerId = 1
@subscriptionId = 1
@invoiceId = 1

### Health check
GET {{baseUrl}}/actuator/health

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "demo@alvarolomba.dev",
  "fullName": "Portfolio User",
  "password": "DemoPassword123!"
}

### Login
# Copy accessToken from the response into @token above.
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "demo@alvarolomba.dev",
  "password": "DemoPassword123!"
}

### Current user
GET {{baseUrl}}/auth/me
Authorization: Bearer {{token}}

### Create plan
# Copy id from the response into @planId above.
POST {{baseUrl}}/plans
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Pro",
  "priceCents": 2900,
  "currency": "USD",
  "billingInterval": "MONTHLY",
  "trialDays": 14
}

### List plans
GET {{baseUrl}}/plans
Authorization: Bearer {{token}}

### Create customer
# Copy id from the response into @customerId above.
POST {{baseUrl}}/customers
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "email": "buyer@example.com",
  "name": "Buyer One",
  "company": "Acme Inc"
}

### List customers
GET {{baseUrl}}/customers
Authorization: Bearer {{token}}

### Create subscription
# Copy id from the response into @subscriptionId above.
POST {{baseUrl}}/subscriptions
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "customerId": {{customerId}},
  "planId": {{planId}}
}

### List subscriptions
GET {{baseUrl}}/subscriptions
Authorization: Bearer {{token}}

### List invoices
# Copy the first invoice id into @invoiceId above.
GET {{baseUrl}}/invoices
Authorization: Bearer {{token}}

### Pay invoice
PATCH {{baseUrl}}/invoices/{{invoiceId}}/pay
Authorization: Bearer {{token}}

### Billing stats
GET {{baseUrl}}/billing/stats
Authorization: Bearer {{token}}

### Cancel subscription
PATCH {{baseUrl}}/subscriptions/{{subscriptionId}}/cancel
Authorization: Bearer {{token}}
